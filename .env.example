# Zendesk 连接配置
# 获取方式: Zendesk Admin → Apps and integrations → Zendesk API → Token

# Zendesk 子域名 (例如你的 URL 是 https://example.zendesk.com，则填 example)
ZENDESK_SUBDOMAIN=your-subdomain

# 你的 Zendesk 账号邮箱
ZENDESK_EMAIL=your-email@example.com

# API Token (在 Zendesk 后台生成)
ZENDESK_API_TOKEN=your-api-token
